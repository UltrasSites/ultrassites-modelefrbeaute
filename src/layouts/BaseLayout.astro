---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';
import '../styles/global.css';

const lang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

/* --- INFOS COULEURS PRO+ --- */
/* On garde la cohérence : Gray-50 (Light) / Gray-900 (Dark) */
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link rel="icon" type="image/png" href="/pro+.png" />
    
    <title>Ultras sites - Modèle PRO+</title>
    <meta name="description" content="Construisez votre site, ultra-rapide, économiser avec hébergement, modèle site pro+" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content="Ultras sites - Modèle PRO+" />
    <meta property="og:description" content="Construisez votre site, ultra-rapide, économiser avec hébergement, modèle site pro+" />

    <!-- Préchargement des fonts système pour éviter FOUC -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <style is:inline>
      /* Styles critiques inline pour éviter FOUC */
      * {
        box-sizing: border-box;
      }
      
      html {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      /* Light Mode (Défaut) */
      html, body {
        background-color: #0a0a0a; /* neutral-950 */
        color: #ffffff;             /* white */
        margin: 0; 
        padding: 0;
        min-height: 100vh;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      }

      /* Dark Mode (Activé via JS) - ici c'est déjà dark par défaut */
      html.dark, html.dark body {
        background-color: #111827 !important; /* bg-gray-900 */
        color: #f9fafb !important;            /* text-gray-50 */
      }
      
      /* Prévenir le flash de scrollbar */
      body {
        overflow-x: hidden;
      }
      
      /* Styles critiques pour le header */
      header {
        position: fixed;
        top: 0;
        width: 100%;
        z-index: 40;
        background: transparent;
      }
    </style>

    <script is:inline>
      (function() {
        // A. THEME - Appliqué immédiatement avant render
        const theme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        
        if (theme === 'dark' || (!theme && systemDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }

        // B. LANGUE (géré par cookie et middleware, plus de query params)
      })();
    </script>
  </head>

  <body class="bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-50 antialiased transition-colors duration-300">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>