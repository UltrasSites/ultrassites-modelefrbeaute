---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import type { Lang } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const { title, description, lang } = Astro.props;
const pageTitle = title || "Beauté & Bien-être Cannes & Nice - Démo | ultras-sites.com";
const pageDescription = description || "Démo site vitrine coiffure, institut, barber, ongles, bien-être à Cannes, Nice et la Côte d'Azur. Création site web salon beauté Cannes, institut bien-être Nice. Modèle proposé par ultras-sites.com.";
const currentLang = lang ?? 'fr';
const htmlLang = currentLang === 'pt' ? 'pt-PT' : currentLang === 'en' ? 'en-US' : currentLang;
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth" data-lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#F5F0EB" />
    <link rel="preconnect" href="https://images.unsplash.com" />
    <link rel="dns-prefetch" href="https://images.unsplash.com" />
    <link rel="preload" as="image" href="/hero-beaute.jpg" fetchpriority="high" />
    <script is:inline>
      (function(){var t=typeof localStorage!=='undefined'&&localStorage.getItem('theme');if(!t){localStorage.setItem('theme','dark');document.documentElement.dataset.theme='dark';}else if(t==='dark'){document.documentElement.dataset.theme='dark';}})();
    </script>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="keywords" content="site web salon coiffure, site web institut beauté Cannes, création site bien-être Nice, web beauté Côte d'Azur" />
    <meta name="geo.region" content="FR-PAC" />
    <meta name="geo.placename" content="Cannes" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{pageTitle}</title>

    <style is:inline>
      /* No visibility:hidden — avoids LCP penalty on PageSpeed */
      html { background-color: #F5F0EB; }
      html.loaded body { opacity: 1; }
      body { opacity: 1; }
    </style>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        document.documentElement.classList.add("loaded");
      });
      setTimeout(() => document.documentElement.classList.add("loaded"), 100);

      (function(){ var L = document.documentElement.getAttribute('data-lang'); if(L) try { localStorage.setItem('lang', L); } catch(e) {} })();

      window.__toggleTheme = function () {
        const root = document.documentElement;
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        if (next === "light") {
          root.removeAttribute("data-theme");
        } else {
          root.dataset.theme = "dark";
        }
        window.localStorage.setItem("theme", next);
      };
    </script>
  </head>

  <body class="text-[#2C2A29] antialiased selection:bg-[#D4B2A7] selection:text-white">
    <Header lang={currentLang} />
    <main>
      <slot />
    </main>
    <Footer lang={currentLang} />
  </body>
</html>
