---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';
import '../styles/global.css';

const lang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="robots" content="index,follow" />
    <link rel="shortcut icon" type="image/png" href="/pro+.png" />
    <link rel="apple-touch-icon" href="/pro+.png" />
    
    <title>Ultras Sites - Modèle PRO+</title>
    <meta name="description" content="Modèle Pro+, ultra-performance et design sombre." />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <style is:inline>
      /* Défaut : Dark Mode pur */
      html { background-color: #0a0a0a; color: #ffffff; }
      body { margin: 0; min-height: 100vh; overflow-x: hidden; }

      /* Protection FOUC */
      html.js-loading body { visibility: hidden; opacity: 0; }
      body { visibility: visible; opacity: 1; transition: opacity 0.3s ease-in; }
    </style>

    <script is:inline>
      // Anti-FOUC
      document.documentElement.classList.add('js-loading');
      window.addEventListener('DOMContentLoaded', () => document.documentElement.classList.remove('js-loading'));
      setTimeout(() => document.documentElement.classList.remove('js-loading'), 500);

      // Le thème est forcé "Dark" par design, mais on garde la structure si besoin d'évoluer
      document.documentElement.classList.add('dark');
    </script>
  </head>

  <body class="bg-neutral-950 text-white antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>