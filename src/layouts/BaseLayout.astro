---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const pageTitle = Astro.props.title || "Beauté & Bien-être - Démo | ultras-sites.com";
const description = Astro.props.description || "Démo site vitrine coiffure, institut, barber, ongles, bien-être. Modèle proposé par ultras-sites.com.";
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <title>{pageTitle}</title>

    <style is:inline>
      html { background-color: #F5F0EB; visibility: hidden; opacity: 0; }
      html.loaded { visibility: visible; opacity: 1; transition: opacity 0.5s ease-in; }
    </style>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        document.documentElement.classList.add("loaded");
        const stored = window.localStorage.getItem("theme");
        if (stored === "dark") {
          document.documentElement.dataset.theme = "dark";
        }
      });
      setTimeout(() => document.documentElement.classList.add("loaded"), 300);

      window.__toggleTheme = function () {
        const root = document.documentElement;
        const next = root.dataset.theme === "dark" ? "light" : "dark";
        if (next === "light") {
          root.removeAttribute("data-theme");
        } else {
          root.dataset.theme = "dark";
        }
        window.localStorage.setItem("theme", next);
      };
    </script>
  </head>

  <body class="text-[#2C2A29] antialiased selection:bg-[#D4B2A7] selection:text-white">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
