---
import { translations, type Lang } from '../i18n/translations';
const langParam = Astro.url.searchParams.get('lang');
const lang: Lang = langParam === 'en' ? 'en' : 'fr';
const t = translations[lang];
---

<footer class="bg-black text-white py-16 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-8">
    
    <div class="text-center md:text-left">
        <span class="font-serif italic text-2xl">Signature.</span>
        <p class="text-neutral-500 text-sm mt-2">{t.footerText}</p>
    </div>

    <div class="flex gap-8 text-xs uppercase tracking-widest text-neutral-500">
        <a href={`/${lang}/legal/cgv`} class="hover:text-emerald-500 transition">{t.nav.legal}</a>
        <a href={`/${lang}/legal/privacy`} class="hover:text-emerald-500 transition">{t.nav.privacy}</a>
    </div>

  </div>
</footer>