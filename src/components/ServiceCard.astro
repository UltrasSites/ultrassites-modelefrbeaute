---
const { title, desc } = Astro.props;
---

<div class="group relative bg-neutral-900/50 border border-white/5 p-8 rounded-2xl overflow-hidden hover:border-purple-500/30 transition-all duration-500">
  <div class="absolute -right-10 -top-10 w-32 h-32 bg-purple-600/20 rounded-full blur-3xl group-hover:bg-purple-600/40 transition-all duration-700"></div>
  
  <h3 class="relative text-xl font-medium text-white mb-4 group-hover:text-purple-300 transition-colors">{title}</h3>
  <p class="relative text-neutral-400 leading-relaxed font-light text-sm">{desc}</p>
  
  <div class="absolute bottom-0 left-0 h-1 bg-gradient-to-r from-purple-600 to-blue-600 w-0 group-hover:w-full transition-all duration-500"></div>
</div>