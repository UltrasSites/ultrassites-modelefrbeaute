---
const { title, desc } = Astro.props;
---

<div class="group relative bg-[#FCFAF8] border border-gray-100 p-8 rounded-sm overflow-hidden hover:border-[#D4B2A7] transition-all duration-500">
  <h3 class="relative text-xl font-serif text-black mb-4 group-hover:text-[#D4B2A7] transition-colors">{title}</h3>
  <p class="relative text-gray-600 leading-relaxed font-light text-sm">{desc}</p>
  <div class="absolute bottom-0 left-0 h-0.5 bg-[#D4B2A7] w-0 group-hover:w-full transition-all duration-500"></div>
</div>