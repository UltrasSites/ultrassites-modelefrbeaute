---
import { translations } from '../i18n/translations';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = translations[lang];
const isHome = Astro.url.pathname === `/${lang}/` || Astro.url.pathname === `/${lang}`;
const linkPrefix = isHome ? '' : `/${lang}/`;
---

<header id="desktop-header" class="hidden md:block fixed top-0 w-full z-50 transition-all duration-500 bg-neutral-950/80 backdrop-blur-md border-b border-white/5">
  <nav class="max-w-7xl mx-auto px-6 h-24 flex justify-between items-center">
    <a href={`/${lang}/`} class="text-2xl font-serif italic text-white tracking-widest relative group">
      {t.siteTitle}<span class="text-emerald-500 not-italic group-hover:text-white transition-colors">.</span>
    </a>
    <div class="flex items-center gap-12">
      <div class="flex gap-8 text-xs font-bold text-white uppercase tracking-[0.2em]">
        <a href={`${linkPrefix}#home`} class="nav-link hover:text-emerald-400 transition-colors py-2">{t.nav.home}</a>
        <a href={`${linkPrefix}#about`} class="nav-link hover:text-emerald-400 transition-colors py-2">{t.nav.about}</a>
        <a href={`${linkPrefix}#services`} class="nav-link hover:text-emerald-400 transition-colors py-2">{t.nav.services}</a>
        <a href={`${linkPrefix}#contact`} class="nav-link hover:text-emerald-400 transition-colors py-2">{t.nav.contact}</a>
      </div>
      <div class="flex gap-4 text-xs font-bold text-white/50 border-l border-white/20 pl-6">
        <button class="hover:text-white transition cursor-pointer uppercase" data-lang="fr">FR</button>
        <button class="hover:text-white transition cursor-pointer uppercase" data-lang="en">EN</button>
      </div>
    </div>
  </nav>
</header>

<div class="md:hidden fixed top-0 left-0 w-full p-6 z-40 pointer-events-none mix-blend-difference">
    <a href={`/${lang}/`} class="pointer-events-auto text-xl font-serif italic text-white tracking-widest">
      {t.siteTitle}<span class="text-emerald-500 not-italic">.</span>
    </a>
</div>

<button id="mobile-fab" class="md:hidden fixed bottom-8 right-8 z-[60] w-14 h-14 bg-emerald-600 text-white rounded-full shadow-[0_0_20px_rgba(16,185,129,0.4)] flex items-center justify-center transition-all duration-300 active:scale-90 hover:bg-emerald-500" aria-label="Menu">
    <div id="icon-burger" class="flex flex-col gap-1.5 transition-all duration-300">
        <span class="w-6 h-0.5 bg-white block"></span>
        <span class="w-4 h-0.5 bg-white block ml-auto"></span>
        <span class="w-6 h-0.5 bg-white block"></span>
    </div>
    <svg id="icon-close" class="w-6 h-6 absolute opacity-0 rotate-90 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
</button>

<div id="menu-backdrop" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-500 md:hidden"></div>

<div id="mobile-drawer" class="fixed top-0 right-0 h-[100dvh] w-[85%] max-w-[320px] bg-neutral-900 border-l border-white/10 z-50 transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] shadow-2xl flex flex-col md:hidden touch-pan-x">
    
    <div class="absolute top-1/2 left-4 -translate-y-1/2 flex flex-col items-center gap-1 opacity-20 pointer-events-none">
        <div class="w-1 h-12 bg-white/50 rounded-full"></div>
        <span class="text-[9px] uppercase -rotate-90 mt-4 tracking-widest text-white">Swipe</span>
    </div>

    <div class="p-10 pt-20 flex flex-col h-full">
        <nav class="flex flex-col gap-8">
            <a href={`${linkPrefix}#home`} class="drawer-link text-3xl font-serif italic text-white/50 hover:text-white transition-colors hover:translate-x-2 duration-300 flex items-center gap-4">
                <span class="text-xs font-sans text-emerald-500 font-bold opacity-0 group-hover:opacity-100 transition-opacity">01</span>
                {t.nav.home}
            </a>
            <a href={`${linkPrefix}#about`} class="drawer-link text-3xl font-serif italic text-white/50 hover:text-white transition-colors hover:translate-x-2 duration-300 flex items-center gap-4">
                <span class="text-xs font-sans text-emerald-500 font-bold opacity-0 group-hover:opacity-100 transition-opacity">02</span>
                {t.nav.about}
            </a>
            <a href={`${linkPrefix}#services`} class="drawer-link text-3xl font-serif italic text-white/50 hover:text-white transition-colors hover:translate-x-2 duration-300 flex items-center gap-4">
                <span class="text-xs font-sans text-emerald-500 font-bold opacity-0 group-hover:opacity-100 transition-opacity">03</span>
                {t.nav.services}
            </a>
            <a href={`${linkPrefix}#contact`} class="drawer-link text-3xl font-serif italic text-emerald-500 hover:text-emerald-400 transition-colors hover:translate-x-2 duration-300 flex items-center gap-4">
                <span class="text-xs font-sans text-white font-bold opacity-0 group-hover:opacity-100 transition-opacity">04</span>
                {t.nav.contact}
            </a>
        </nav>

        <div class="mt-auto mb-8 border-t border-white/10"></div>

        <div class="flex justify-between items-center">
            <div class="flex gap-4">
                <button class="text-xs font-bold text-white/50 hover:text-white uppercase tracking-widest border border-white/20 px-3 py-2 rounded hover:border-emerald-500 transition-all" data-lang="fr">FR</button>
                <button class="text-xs font-bold text-white/50 hover:text-white uppercase tracking-widest border border-white/20 px-3 py-2 rounded hover:border-emerald-500 transition-all" data-lang="en">EN</button>
            </div>
            
            <div class="text-[10px] text-white/30 uppercase tracking-widest">
                Pro+ Series
            </div>
        </div>
    </div>
</div>

<script>
  // SCRIPT GESTION UX MOBILE
  const fab = document.getElementById('mobile-fab');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.getElementById('menu-backdrop');
  const iconBurger = document.getElementById('icon-burger');
  const iconClose = document.getElementById('icon-close');
  const links = document.querySelectorAll('.drawer-link');

  let isOpen = false;

  // Fonction Ouvrir/Fermer
  function toggleDrawer(forceClose = false) {
    if (forceClose) isOpen = true; // Pour forcer la fermeture via la logique inverse ci-dessous
    
    isOpen = !isOpen;

    if (isOpen) {
        // OPEN
        drawer?.classList.remove('translate-x-full');
        backdrop?.classList.remove('hidden');
        // Petit délai pour l'opacité (transition CSS)
        setTimeout(() => backdrop?.classList.remove('opacity-0'), 10);
        
        // Anim Icone
        iconBurger?.classList.add('opacity-0', 'rotate-90');
        iconClose?.classList.remove('opacity-0', 'rotate-90');
        
        document.body.style.overflow = 'hidden';
    } else {
        // CLOSE
        drawer?.classList.add('translate-x-full');
        backdrop?.classList.add('opacity-0');
        setTimeout(() => backdrop?.classList.add('hidden'), 500);
        
        // Anim Icone
        iconBurger?.classList.remove('opacity-0', 'rotate-90');
        iconClose?.classList.add('opacity-0', 'rotate-90');
        
        document.body.style.overflow = '';
    }
  }

  // Clics
  fab?.addEventListener('click', () => toggleDrawer());
  backdrop?.addEventListener('click', () => toggleDrawer());
  links.forEach(l => l.addEventListener('click', () => toggleDrawer(true)));

  // GESTION DU SWIPE (Glisser pour fermer)
  let touchStartX = 0;
  let touchEndX = 0;

  drawer?.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].screenX;
  }, {passive: true});

  drawer?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].screenX;
    handleSwipe();
  }, {passive: true});

  function handleSwipe() {
    // Si on glisse de gauche à droite (vers le bord droit) de plus de 50px
    if (touchEndX - touchStartX > 50) {
        if (isOpen) toggleDrawer(); // Fermer
    }
  }

  // Langue (Commun Desktop/Mobile)
  document.querySelectorAll('[data-lang]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const lang = (e.currentTarget as HTMLElement).dataset.lang;
      document.cookie = `lang=${lang}; Path=/; Max-Age=31536000; SameSite=Lax`;
      const newPath = window.location.pathname.replace(/^\/(fr|en)/, `/${lang}`);
      window.location.href = newPath;
    });
  });
</script>