---
import { type Lang } from '../i18n/utils';
import { translations } from '../i18n/translations';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props { lang?: Lang; }

const lang = Astro.props.lang ?? 'fr';
const t = translations[lang];
const base = `/${lang}`;

const links = [
  { name: t.nav_institut, href: `${base}/#institut` },
  { name: t.nav_prestations, href: `${base}/#prestations` },
  { name: t.nav_agenda, href: `${base}/#agenda` },
  { name: t.nav_avis, href: `${base}/#avis` },
  { name: t.nav_contact, href: `${base}/#contact` },
];
---

<!-- Desktop : logo + nav + boutons toujours visibles ; barre transparente en haut, pleine au scroll -->
<header id="desktop-header" class="hidden md:flex fixed top-0 w-full z-50 transition-all duration-300 h-14 items-center justify-between px-6 md:px-8 nav-transparent hover:bg-white/95 hover:backdrop-blur-md">
    <a href={base + '/'} class="flex items-center gap-2 group">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-6 h-6 text-[#D4B2A7] group-hover:text-black transition-colors"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        <span class="text-lg font-serif tracking-[0.2em] text-black">Beauté & <span class="text-[#D4B2A7]">Bien-être.</span></span>
    </a>

    <nav class="flex gap-8 text-xs font-bold text-gray-800 uppercase tracking-[0.15em]">
        {links.map(link => (
            <a href={link.href} class="hover:text-[#D4B2A7] transition-colors py-2">{link.name}</a>
        ))}
    </nav>

    <div id="header-cta" class="flex items-center gap-4">
        <button
            type="button"
            class="flex items-center justify-center w-9 h-9 border border-gray-200/80 bg-white/80 text-gray-700 hover:bg-black hover:text-white rounded-full transition-colors"
            onclick="window.__toggleTheme && window.__toggleTheme()"
            aria-label={t.nav_aria_theme}
        >
            <span class="theme-toggle-icon-sun">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                    <circle cx="12" cy="12" r="4" />
                    <path d="M12 2v2.5M12 19.5V22M4.22 4.22l1.77 1.77M17.99 17.99l1.79 1.79M2 12h2.5M19.5 12H22M4.22 19.78l1.77-1.77M17.99 6.01l1.79-1.79" />
                </svg>
            </span>
            <span class="theme-toggle-icon-moon">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                    <path d="M21 12.79A9 9 0 0111.21 3 7 7 0 0012 17a7 7 0 009-4.21z" />
                </svg>
            </span>
        </button>
        <LanguageSwitcher currentLang={lang} variant="header" />
        <a href={`${base}/#prestations`} class="text-[9px] font-bold uppercase tracking-widest text-gray-500 hover:text-black transition-colors">{t.nav_voir_offres}</a>
        <a href={`${base}/#agenda`} class="px-5 py-2.5 bg-black text-white text-[9px] font-bold uppercase tracking-[0.2em] hover:bg-[#D4B2A7] transition-colors rounded-sm">{t.nav_rdv}</a>
    </div>
</header>

<!-- Mobile : logo flottant, pas de barre, au-dessus de la page -->
<div id="mobile-logo" class="md:hidden fixed top-6 left-6 z-40">
    <a href={base + '/'} class="flex items-center gap-2 text-black drop-shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" class="w-7 h-7 text-[#D4B2A7]"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
        <span class="text-xl font-serif tracking-[0.15em] font-medium">Beauté & <span class="text-[#D4B2A7]">Bien-être.</span></span>
    </a>
</div>

<!-- Mobile : dock centré pastille liquid glass (thème + contact + Menu/RDV) -->
<div class="mobile-dock md:hidden" aria-label="Actions principales">
    <div class="mobile-dock-inner">
        <button type="button" class="dock-btn dock-btn-theme" onclick="window.__toggleTheme && window.__toggleTheme()" aria-label={t.nav_aria_theme}>
            <span class="theme-toggle-icon-sun">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="12" r="4" /><path d="M12 2v2.5M12 19.5V22M4.22 4.22l1.77 1.77M17.99 17.99l1.79 1.79M2 12h2.5M19.5 12H22M4.22 19.78l1.77-1.77M17.99 6.01l1.79-1.79" /></svg>
            </span>
            <span class="theme-toggle-icon-moon">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M21 12.79A9 9 0 0111.21 3 7 7 0 0012 17a7 7 0 009-4.21z" /></svg>
            </span>
        </button>
        <span class="dock-sep"></span>
        <a href={`${base}/#contact`} class="dock-btn dock-btn-phone" aria-label={t.nav_aria_contact}>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
        </a>
        <span class="dock-sep"></span>
        <button id="mobile-menu-rdv-btn" type="button" class="dock-btn dock-btn-menu mobile-fab mode-rdv relative" aria-label={t.nav_aria_menu_rdv} data-base={base}>
            <span id="mobile-fab-label" class="mobile-fab-text text-xs font-bold uppercase tracking-widest">RDV</span>
            <span id="mobile-fab-bars" class="mobile-fab-bars hidden absolute inset-0 flex flex-col gap-1 items-center justify-center pointer-events-none">
                <span class="w-5 h-px bg-white block"></span><span class="w-4 h-px bg-white block"></span><span class="w-3 h-px bg-white block"></span>
            </span>
            <svg id="mobile-fab-close" class="w-6 h-6 absolute inset-0 m-auto opacity-0 pointer-events-none transition-opacity duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
    </div>
</div>

<style>
    .mobile-dock { position: fixed; bottom: calc(1.5rem + env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%); z-index: 60; display: flex; justify-content: center; }
    @media (min-width: 768px) { .mobile-dock { display: none !important; } }
    .mobile-dock-inner { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 99px; background: rgba(252,250,248,0.92); backdrop-filter: blur(24px) saturate(180%); -webkit-backdrop-filter: blur(24px) saturate(180%); border: 1px solid rgba(0,0,0,0.06); box-shadow: inset 0 1px 0 rgba(255,255,255,0.4), 0 8px 32px rgba(0,0,0,0.12); }
    html[data-theme='dark'] .mobile-dock-inner { background: rgba(26, 26, 26, 0.92); border-color: rgba(255,255,255,0.1); }
    .dock-btn { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 0.2s ease; box-shadow: 0 4px 14px rgba(0,0,0,0.1); text-decoration: none; }
    .dock-btn:active { transform: scale(0.9); }
    .dock-btn-theme { background: #fff; color: #1a1a1a; border: 1px solid rgba(0,0,0,0.08); }
    html[data-theme='dark'] .dock-btn-theme { background: #2a2a2a; color: #fff; border-color: rgba(255,255,255,0.1); }
    .dock-btn-phone { background: linear-gradient(135deg, #22c55e 0%, #15803d 100%); color: #fff; }
    .dock-btn-menu.mode-rdv { background: #D4B2A7; color: white; }
    .dock-btn-menu.mode-menu { background: #1a1a1a; color: white; }
    html[data-theme='dark'] .dock-btn-menu.mode-rdv, html[data-theme='dark'] .dock-btn-menu.mode-menu { background: #fff; color: #1a1a1a; }
    .dock-sep { width: 1px; height: 28px; background: rgba(0,0,0,0.1); flex-shrink: 0; }
    html[data-theme='dark'] .dock-sep { background: rgba(255,255,255,0.15); }
    .menu-overlay { background: rgba(0,0,0,0.6); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); transition: opacity 0.4s; }
    .menu-panel-sheet { background: rgba(252,248,244,0.98); backdrop-filter: blur(24px) saturate(180%); -webkit-backdrop-filter: blur(24px) saturate(180%); border-top: 1px solid rgba(232,121,160,0.18); box-shadow: inset 0 1px 1px rgba(255,255,255,0.6), 0 -8px 32px rgba(0,0,0,0.10); }
    html[data-theme='dark'] .menu-panel-sheet { background: rgba(28,18,24,0.98); border-top-color: rgba(232,121,160,0.2); box-shadow: inset 0 1px 1px rgba(255,255,255,0.04), 0 -8px 32px rgba(0,0,0,0.35); }
</style>

<div id="mobile-drawer" class="fixed inset-0 z-[70] translate-y-full transition-transform duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] md:hidden flex items-end">
    <div id="backdrop" class="menu-overlay absolute inset-0 opacity-0 transition-opacity duration-400 z-[65]"></div>
    <div class="drawer-panel menu-panel-sheet relative w-full rounded-t-[32px] shadow-2xl flex flex-col p-6 pb-32 max-h-[88vh] overflow-y-auto z-[71]">
        <p class="text-[10px] uppercase tracking-widest text-gray-500 mb-4 flex items-center justify-center gap-2" aria-hidden="true">
            <span class="inline-block w-8 h-0.5 bg-current opacity-60 rounded"></span>
            Glissez vers le bas pour fermer
        </p>
        <div class="flex justify-between items-center mb-8">
            <span class="text-xs font-bold uppercase tracking-[0.3em] text-[#D4B2A7]">{t.drawer_nav}</span>
            <button id="close-btn" type="button" class="p-2.5 text-[#e879a0] hover:text-white rounded-full bg-[#fce8f0] hover:bg-[#e879a0] shadow-md hover:shadow-lg transition-all" aria-label={t.drawer_close}>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>

        <nav class="flex flex-col gap-4">
            {links.map(link => (
                <a href={link.href} class="drawer-link text-2xl font-serif text-black hover:text-[#D4B2A7] transition-colors py-1">{link.name}</a>
            ))}
            <a href={`${base}/#agenda`} class="drawer-link flex items-center justify-center gap-2 w-full py-4 bg-black text-white text-xs font-bold uppercase tracking-[0.2em] rounded-xl hover:bg-[#D4B2A7] transition-colors mt-2">{t.drawer_rdv}</a>
            <LanguageSwitcher currentLang={lang} variant="drawer" />
            <div class="flex gap-4 pt-6 border-t border-gray-200 mt-4">
                <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" class="drawer-link flex items-center justify-center w-12 h-12 rounded-full bg-[#F4EBE8] text-[#D4B2A7] hover:bg-[#D4B2A7] hover:text-white transition-all" aria-label="Instagram">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                </a>
                <a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" class="drawer-link flex items-center justify-center w-12 h-12 rounded-full bg-[#F4EBE8] text-[#D4B2A7] hover:bg-[#D4B2A7] hover:text-white transition-all" aria-label="Facebook">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
            </div>
        </nav>
    </div>
</div>

<script>
    const header = document.getElementById('desktop-header');
    const scrollThreshold = 80;
    function updateHeader() {
        if (!header) return;
        const scrolled = window.scrollY > scrollThreshold;
        header.classList.toggle('nav-scrolled', scrolled);
        header.classList.toggle('nav-transparent', !scrolled);
    }
    window.addEventListener('scroll', updateHeader);
    updateHeader();

    const mobileFab = document.getElementById('mobile-menu-rdv-btn');
    const mobileFabLabel = document.getElementById('mobile-fab-label');
    const mobileFabBars = document.getElementById('mobile-fab-bars');
    const fabScrollThreshold = 180;

    // Animation : Menu 0.5s / RDV 0.5s / Menu 0.5s / RDV 0.5s / Barres 20s, à l’infini
    let fabState = 0;
    let barsTicks = 0;
    const BARS_DURATION_TICKS = 40; // 40 × 500ms = 20s
    setInterval(() => {
        if (!mobileFabLabel || !mobileFabBars || drawerOpen) return;
        if (fabState === 4) {
            barsTicks++;
            if (barsTicks >= BARS_DURATION_TICKS) {
                barsTicks = 0;
                fabState = 0;
            } else return;
        } else {
            fabState++;
        }
        if (fabState === 4) {
            mobileFabLabel.classList.add('hidden');
            mobileFabBars.classList.remove('hidden');
            mobileFab?.classList.add('mode-menu');
            mobileFab?.classList.remove('mode-rdv');
        } else {
            mobileFabBars.classList.add('hidden');
            mobileFabLabel.classList.remove('hidden');
            const isMenu = fabState === 0 || fabState === 2;
            mobileFabLabel.textContent = isMenu ? 'Menu' : 'RDV';
            mobileFab?.classList.toggle('mode-rdv', !isMenu);
            mobileFab?.classList.toggle('mode-menu', isMenu);
        }
    }, 500);

    const btn = document.getElementById('mobile-menu-rdv-btn');
    const close = document.getElementById('close-btn');
    const drawer = document.getElementById('mobile-drawer');
    const backdrop = document.getElementById('backdrop');
    const drawerPanel = drawer?.querySelector('.drawer-panel');
    let drawerOpen = false;

    const fabLabel = document.getElementById('mobile-fab-label');
    const fabBars = document.getElementById('mobile-fab-bars');
    const fabClose = document.getElementById('mobile-fab-close');

    function toggleMenu(open?: boolean) {
        if (!drawer || !backdrop) return;
        const shouldOpen = open !== undefined ? open : !drawerOpen;
        drawerOpen = shouldOpen;
        if (shouldOpen) {
            drawer.classList.remove('translate-y-full');
            backdrop.classList.remove('opacity-0');
            document.body.style.overflow = 'hidden';
            fabLabel?.classList.add('hidden');
            fabBars?.classList.add('hidden');
            fabClose?.classList.remove('opacity-0');
            mobileFab?.classList.add('mode-menu');
        } else {
            drawer.classList.add('translate-y-full');
            backdrop.classList.add('opacity-0');
            document.body.style.overflow = '';
            fabClose?.classList.add('opacity-0');
            if (fabState === 4) {
                fabLabel?.classList.add('hidden');
                fabBars?.classList.remove('hidden');
            } else {
                fabLabel?.classList.remove('hidden');
                fabBars?.classList.add('hidden');
            }
        }
    }

    btn?.addEventListener('click', () => toggleMenu());
    close?.addEventListener('click', () => toggleMenu(false));
    backdrop?.addEventListener('click', () => toggleMenu(false));
    document.querySelectorAll('.drawer-link').forEach(l => l.addEventListener('click', () => toggleMenu(false)));

    // Swipe vers le bas pour fermer le drawer (sur le panel)
    let touchStartY = 0;
    drawerPanel?.addEventListener('touchstart', (e) => { touchStartY = (e as TouchEvent).touches[0].clientY; }, { passive: true });
    drawerPanel?.addEventListener('touchend', (e) => {
        const te = e as TouchEvent;
        const diff = te.changedTouches[0].clientY - touchStartY;
        if (diff > 80) toggleMenu(false);
    }, { passive: true });
</script>
