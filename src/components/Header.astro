---
import { translations } from '../i18n/translations';
const { lang = 'fr' } = Astro.params;
const t = translations[lang as 'fr' | 'en'];

// Vérifie si on est sur la page d'accueil
const isHome = Astro.url.pathname === `/${lang}/` || Astro.url.pathname === `/${lang}`;
const linkPrefix = isHome ? '' : `/${lang}/`;
---

<header id="smart-header" class="fixed top-0 w-full z-40 transition-all duration-500 bg-transparent">
  <nav class="max-w-7xl mx-auto px-6 h-24 flex justify-between items-center">
    
    <a href={`/${lang}/`} class="text-2xl font-serif italic text-white tracking-widest z-50 relative group">
      {t.siteTitle}<span class="text-emerald-500 not-italic group-hover:text-white transition-colors">.</span>
    </a>

    <a href={`${linkPrefix}#blog`} class="nav-link relative hover:text-emerald-400 transition-colors py-2" data-section="blog">
    Journal
    <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-emerald-500 transition-all duration-300 group-hover:w-full"></span>
</a>
    
    <div class="hidden md:flex items-center gap-12">
      <div class="flex gap-8 text-xs font-bold text-white uppercase tracking-[0.2em]">
        <a href={`${linkPrefix}#home`} class="nav-link relative hover:text-emerald-400 transition-colors py-2" data-section="home">
            {t.nav.home}
            <span class="absolute bottom-0 left-0 w-0 h-[1px] bg-emerald-500 transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href={`${linkPrefix}#about`} class="nav-link relative hover:text-emerald-400 transition-colors py-2" data-section="about">
            {t.nav.about}
        </a>
        <a href={`${linkPrefix}#services`} class="nav-link relative hover:text-emerald-400 transition-colors py-2" data-section="services">
            {t.nav.services}
        </a>
        <a href={`${linkPrefix}#contact`} class="nav-link relative hover:text-emerald-400 transition-colors py-2" data-section="contact">
            {t.nav.contact}
        </a>
      </div>

      <div class="flex gap-4 text-xs font-bold text-white/50 border-l border-white/20 pl-6">
        <a href={`/fr/`} class={`hover:text-white transition ${lang === 'fr' ? 'text-white' : ''}`}>FR</a>
        <a href={`/en/`} class={`hover:text-white transition ${lang === 'en' ? 'text-white' : ''}`}>EN</a>
      </div>
    </div>
  </nav>
</header>

<a href="#contact" class="hidden md:flex fixed bottom-8 right-8 z-50 w-16 h-16 bg-emerald-600 rounded-full items-center justify-center text-white shadow-[0_0_20px_rgba(16,185,129,0.4)] hover:scale-110 transition-all duration-300 animate-bounce-slow">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
       <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
</a>