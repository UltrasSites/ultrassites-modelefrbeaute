---
import { translations } from '../i18n/translations';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = translations[lang];
const isHome = Astro.url.pathname === `/${lang}/` || Astro.url.pathname === `/${lang}`;
const linkPrefix = isHome ? '' : `/${lang}/`;
---

<header id="smart-header" class="fixed top-0 w-full z-50 transition-all duration-500 border-b border-white/5 bg-neutral-950/80 backdrop-blur-md">
  <nav class="max-w-7xl mx-auto px-6 h-24 flex justify-between items-center relative">
    
    <a href={`/${lang}/`} class="text-2xl font-serif italic text-white tracking-widest relative group z-50">
      {t.siteTitle}<span class="text-emerald-500 not-italic group-hover:text-white transition-colors">.</span>
    </a>

    <div class="hidden md:flex items-center gap-12">
      <div class="flex gap-8 text-xs font-bold text-white uppercase tracking-[0.2em]">
        <a href={`${linkPrefix}#home`} class="nav-link hover:text-emerald-400 transition-colors py-2">{t.nav.home}</a>
        <a href={`${linkPrefix}#about`} class="nav-link hover:text-emerald-400 transition-colors py-2">{t.nav.about}</a>
        <a href={`${linkPrefix}#services`} class="nav-link hover:text-emerald-400 transition-colors py-2">{t.nav.services}</a>
        <a href={`${linkPrefix}#contact`} class="nav-link hover:text-emerald-400 transition-colors py-2">{t.nav.contact}</a>
      </div>
      <div class="flex gap-4 text-xs font-bold text-white/50 border-l border-white/20 pl-6">
        <button class="hover:text-white transition cursor-pointer uppercase" data-lang="fr">FR</button>
        <button class="hover:text-white transition cursor-pointer uppercase" data-lang="en">EN</button>
      </div>
    </div>

    <button id="menu-btn" class="md:hidden z-50 text-white p-2 hover:text-emerald-400 transition-colors focus:outline-none group" aria-label="Menu">
        <div class="flex flex-col items-end gap-1.5">
            <span class="w-8 h-0.5 bg-current transition-all duration-300 group-[.open]:rotate-45 group-[.open]:translate-y-2"></span>
            <span class="w-6 h-0.5 bg-current transition-all duration-300 group-[.open]:opacity-0"></span>
            <span class="w-8 h-0.5 bg-current transition-all duration-300 group-[.open]:-rotate-45 group-[.open]:-translate-y-2"></span>
        </div>
    </button>
  </nav>

  <div id="menu-backdrop" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-500"></div>

  <div id="mobile-menu" class="fixed top-0 right-0 h-[100dvh] w-[80%] max-w-[300px] bg-neutral-900 border-l border-white/10 z-40 transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.32,0.72,0,1)] shadow-[-20px_0_50px_rgba(0,0,0,0.5)] flex flex-col pt-32 pb-10 px-8">
    
    <div class="flex flex-col gap-8">
        <a href={`${linkPrefix}#home`} class="mobile-link text-xl font-bold uppercase tracking-widest text-white/80 hover:text-emerald-500 transition-colors flex items-center gap-4 group">
            <span class="w-0 group-hover:w-4 h-[1px] bg-emerald-500 transition-all"></span> {t.nav.home}
        </a>
        <a href={`${linkPrefix}#about`} class="mobile-link text-xl font-bold uppercase tracking-widest text-white/80 hover:text-emerald-500 transition-colors flex items-center gap-4 group">
            <span class="w-0 group-hover:w-4 h-[1px] bg-emerald-500 transition-all"></span> {t.nav.about}
        </a>
        <a href={`${linkPrefix}#services`} class="mobile-link text-xl font-bold uppercase tracking-widest text-white/80 hover:text-emerald-500 transition-colors flex items-center gap-4 group">
            <span class="w-0 group-hover:w-4 h-[1px] bg-emerald-500 transition-all"></span> {t.nav.services}
        </a>
        <a href={`${linkPrefix}#contact`} class="mobile-link text-xl font-bold uppercase tracking-widest text-white/80 hover:text-emerald-500 transition-colors flex items-center gap-4 group">
            <span class="w-0 group-hover:w-4 h-[1px] bg-emerald-500 transition-all"></span> {t.nav.contact}
        </a>
    </div>

    <div class="w-full h-[1px] bg-white/10 my-auto"></div>

    <div class="flex gap-6 mt-8">
      <button class="text-sm font-bold text-white/50 hover:text-white uppercase tracking-widest border border-white/20 px-4 py-2 rounded hover:border-emerald-500 transition-all" data-lang="fr">FR</button>
      <button class="text-sm font-bold text-white/50 hover:text-white uppercase tracking-widest border border-white/20 px-4 py-2 rounded hover:border-emerald-500 transition-all" data-lang="en">EN</button>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const backdrop = document.getElementById('menu-backdrop');
  const links = document.querySelectorAll('.mobile-link');

  function toggleMenu() {
    const isOpen = btn?.classList.contains('open');
    
    if (!isOpen) {
        // OPEN
        btn?.classList.add('open');
        menu?.classList.remove('translate-x-full');
        backdrop?.classList.remove('hidden');
        setTimeout(() => backdrop?.classList.remove('opacity-0'), 10);
        document.body.style.overflow = 'hidden';
    } else {
        // CLOSE
        btn?.classList.remove('open');
        menu?.classList.add('translate-x-full');
        backdrop?.classList.add('opacity-0');
        setTimeout(() => backdrop?.classList.add('hidden'), 500);
        document.body.style.overflow = '';
    }
  }

  btn?.addEventListener('click', toggleMenu);
  backdrop?.addEventListener('click', toggleMenu);
  
  links.forEach(l => l.addEventListener('click', () => {
      toggleMenu();
  }));

  // Logic Language
  document.querySelectorAll('[data-lang]').forEach(el => {
    el.addEventListener('click', (e) => {
      e.preventDefault();
      const lang = (e.currentTarget as HTMLElement).dataset.lang;
      document.cookie = `lang=${lang}; Path=/; Max-Age=31536000; SameSite=Lax`;
      const newPath = window.location.pathname.replace(/^\/(fr|en)/, `/${lang}`);
      window.location.href = newPath;
    });
  });
</script>