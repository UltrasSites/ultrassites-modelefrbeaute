                      <textarea rows="3" placeholder="Votre message" class="w-full bg-transparent border-b border-gray-300 py-3 text-black placeholder-gray-400 focus:border-[#D4B2A7] focus:outline-none resize-none text-sm"></textarea>
                      <button type="button" class="w-full py-4 bg-black text-white text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-[#D4B2A7] transition-colors rounded-sm">Envoyer</button>
