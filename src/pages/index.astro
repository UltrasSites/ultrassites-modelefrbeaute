---
import BaseLayout from '../layouts/BaseLayout.astro';

// Fond hero : placez votre image (salle de soins) dans public/hero-institut.png — sinon le fallback s'affiche
const heroBg = "/hero-institut.png";
const heroBgFallback = "https://images.unsplash.com/photo-1544161515-4ab6ce6db874?q=80&w=2000&auto=format&fit=crop";
// Photo Rita (contact) : public/rita.jpg ou fallback
const ritaPhoto = "/rita.jpg";
const ritaPhotoFallback = "https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=600&auto=format&fit=crop";

// Prestations détaillées avec prix (aligné institut-rita.ch)
const prestations = [
    { category: "Coiffure", title: "Coiffure femme & homme", services: ["Coupe", "Coloration", "Brushing", "Barber"], prices: ["à partir de 35 €", "sur devis", "à partir de 25 €", "à partir de 28 €"], desc: "Coupes, colorations et soins pour toute la famille.", img: "" },
    { category: "Instituts & bien-être", title: "Soins & bien-être", services: ["Soins du visage", "Massages", "Épilation", "Ongles"], prices: ["sur devis", "sur devis", "sur devis", "à partir de 25 €"], desc: "Soins personnalisés et moments de détente.", img: "" },
    { category: "Onglerie", title: "Mains & pieds", services: ["Vernis classique", "Gel / semi-permanent", "Nail art"], prices: ["à partir de 20 €", "à partir de 35 €", "sur devis"], desc: "Mise en beauté des mains et des pieds.", img: "" },
    { category: "Barber", title: "Barber & barbier", services: ["Barbe", "Coupe homme", "Rasage traditionnel"], prices: ["à partir de 15 €", "à partir de 28 €", "à partir de 25 €"], desc: "Coupe et entretien de la barbe, style barbershop.", img: "" }
];

// Avis dans l’esprit du salon (institut-rita.ch : zen, personnalisé, bien-être)
const avis = [
    { name: "C. M.", text: "Un salon zen et chaleureux. Soins personnalisés de grande qualité, je reviens toujours avec plaisir." },
    { name: "S. D.", text: "L’Institut RITA est une vraie parenthèse bien-être. Accueil et professionnalisme au top." },
    { name: "L. B.", text: "J’y vais depuis des années. Un lieu apaisant où le bien-être est vraiment la priorité." }
];

// Images correspondant aux services (soins visage, onglerie, épilation, spa) — URLs stables
const carouselImages = [
    { src: "https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=800&q=80", alt: "Salle de soins" },
    { src: "https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=800&q=80", alt: "Soin du visage" },
    { src: "https://images.unsplash.com/photo-1604654894610-df63bc536371?w=800&q=80", alt: "Onglerie" },
    { src: "https://images.unsplash.com/photo-1560066984-138dadb4c035?w=800&q=80", alt: "Épilation" },
    { src: "https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=800&q=80", alt: "Maquillage" }
];
---

<BaseLayout title="Beauté & Bien-être - Démo | ultras-sites.com" description="Démo site vitrine coiffure, institut, barber, ongles, bien-être. Modèle proposé par ultras-sites.com.">

  <section id="home" class="relative min-h-[95vh] md:min-h-screen w-full flex items-center justify-center px-6 pt-24 overflow-hidden">
      <div class="absolute inset-0 z-0">
          <img id="hero-img" src={heroBgFallback} data-original={heroBg} alt="Salle de soins Institut RITA" class="w-full h-full object-cover object-[50%_50%] md:object-[50%_45%] opacity-90" width="1920" height="1080" loading="eager" decoding="async" referrerpolicy="no-referrer" />
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#FCFAF8_100%)] opacity-60 md:opacity-65"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-[#FCFAF8]/92 via-[#FCFAF8]/65 to-transparent w-full md:w-2/3"></div>
      </div>

      <div class="relative z-10 max-w-7xl w-full mx-auto grid md:grid-cols-2 gap-12 items-center">
          <div class="space-y-6 animate-fade-in-up">
              <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif text-black leading-tight">Coiffure, Institut, Barber & Bien-être</h1>
              <p class="text-[15px] sm:text-base md:text-base text-black/90 font-bold leading-snug max-w-xl">Démo pour salons de coiffure, instituts de beauté, barbershops et centres bien-être. Votre site sera adapté à vos prestations.</p>
              <p class="text-sm text-gray-500 italic">Démo · <a href="https://ultras-sites.com" target="_blank" rel="noopener" class="underline">ultras-sites.com</a></p>
              <div class="hidden md:flex flex-wrap items-center gap-3 py-2">
                  <a href="/#contact" class="flex items-center gap-2 px-4 py-2.5 bg-white/90 backdrop-blur-sm border border-[#D4B2A7]/30 rounded-lg shadow-sm hover:border-[#D4B2A7] transition-all text-sm font-medium text-black">Contact</a>
                  <a href="/#agenda" class="flex items-center gap-2 px-4 py-2.5 bg-white/90 backdrop-blur-sm border border-[#D4B2A7]/30 rounded-lg shadow-sm hover:border-[#D4B2A7] transition-all text-sm font-medium text-black">Prendre RDV (démo)</a>
                  <a href="https://ultras-sites.com" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-10 h-10 rounded-full border border-[#D4B2A7] text-[#D4B2A7] hover:bg-[#D4B2A7] hover:text-white transition-all" aria-label="ultras-sites">ultras</a>
              </div>
              <div class="flex flex-col gap-4 pt-2 md:hidden">
                  <div class="flex flex-col sm:flex-row gap-4">
                      <a href="/#agenda" class="flex items-center justify-center px-8 py-4 bg-black text-white font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-[#D4B2A7] transition-all shadow-xl">Prendre rendez-vous</a>
                      <a href="#prestations" class="flex items-center justify-center px-8 py-4 bg-transparent border border-gray-300 text-black font-bold uppercase tracking-[0.2em] text-[10px] hover:border-black transition-colors">Voir nos offres</a>
                  </div>
                  <div class="flex gap-3">
                      <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-11 h-11 rounded-full bg-white/95 shadow-md border border-gray-200 text-[#C19A8E] hover:bg-[#D4B2A7] hover:text-white hover:border-[#D4B2A7] transition-all shrink-0" aria-label="Instagram">
                          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                      </a>
                      <a href="https://www.facebook.com/" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-11 h-11 rounded-full bg-white/95 shadow-md border border-gray-200 text-[#C19A8E] hover:bg-[#D4B2A7] hover:text-white hover:border-[#D4B2A7] transition-all shrink-0" aria-label="Facebook">
                          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                      </a>
                  </div>
              </div>
          </div>
          <div class="hidden md:flex flex-col items-center text-center animate-fade-in-up order-first md:order-last">
              <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#D4B2A7] mb-4">Votre contact</p>
              <a href="/#agenda" class="block relative w-48 h-56 overflow-hidden rounded-xl shadow-2xl border border-[#D4B2A7]/30 group">
                  <img id="rita-img" src={ritaPhotoFallback} data-original={ritaPhoto} alt="Rita — Institut RITA" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width="192" height="224" loading="eager" decoding="async" referrerpolicy="no-referrer" />
              </a>
              <p class="text-sm font-serif text-black mt-3">Rita</p>
              <div class="flex flex-col sm:flex-row gap-3 mt-6 w-full max-w-xs">
                  <a href="/#agenda" class="flex items-center justify-center px-6 py-3.5 bg-black text-white font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-[#D4B2A7] transition-all rounded-lg">Prendre rendez-vous</a>
                  <a href="#prestations" class="flex items-center justify-center px-6 py-3.5 border border-[#D4B2A7] text-black font-bold uppercase tracking-[0.2em] text-[10px] hover:bg-[#F4EBE8] transition-colors rounded-lg">Voir nos offres</a>
              </div>
          </div>
      </div>
  </section>

  <section id="institut" class="py-32 px-6 bg-[#FCFAF8] relative">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-16 items-center">
          <div class="lg:col-span-7 space-y-8 order-2 lg:order-1">
              <div class="flex items-center gap-4 mb-8">
                  <div class="w-12 h-px bg-[#D4B2A7]"></div>
                  <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#D4B2A7]">L'Éthique Rita</span>
              </div>
              <h2 class="text-4xl md:text-5xl font-serif text-black leading-tight">"Le maquillage permanent ne doit pas transformer, il doit révéler."</h2>
              <div class="text-gray-600 font-light leading-relaxed space-y-6 text-lg">
                  <p>C'est avec cette philosophie que j'ai fondé l'institut. Mon objectif n'est pas d'appliquer des calques standards, mais de lire la morphologie de votre visage pour en faire ressortir la symétrie et la douceur.</p>
                  <p>Spécialisée en techniques de micro-pigmentation avancées, j'utilise exclusivement des pigments organiques de qualité médicale. Chaque détail compte : de la couleur de votre peau à l'inclinaison de votre arcade sourcilière.</p>
              </div>
              <p class="font-serif text-2xl text-[#D4B2A7] tracking-widest pt-4">Rita.</p>
          </div>
          <div class="lg:col-span-5 order-1 lg:order-2 relative px-8 lg:px-0">
              <div class="absolute top-8 -right-4 w-full h-full border border-[#D4B2A7] z-0 hidden md:block"></div>
              <div class="absolute -bottom-8 -left-8 w-48 h-48 bg-[#F4EBE8] rounded-full z-0 blur-2xl opacity-60"></div>
              <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?q=80&w=1000&auto=format&fit=crop" alt="Portrait de la fondatrice" class="relative z-10 w-full aspect-[4/5] object-cover shadow-2xl" width="600" height="750" loading="lazy" decoding="async" />
              <div class="absolute -left-6 top-1/2 -translate-y-1/2 z-20 bg-white p-6 shadow-xl hidden md:block border border-gray-100">
                  <p class="text-3xl font-serif text-black">10+</p>
                  <p class="text-[9px] uppercase tracking-widest text-gray-400 font-bold mt-1">Années d'expertise</p>
              </div>
          </div>
      </div>
  </section>

  <section class="py-20 bg-[#FCFAF8] overflow-hidden border-y border-gray-100/80 flex flex-col gap-8 page-bg">
      <div class="text-center px-6"><span class="text-[10px] font-bold uppercase tracking-[0.3em] text-[#D4B2A7]">Immersion</span></div>
      <p class="md:hidden text-center text-xs text-gray-500 px-4">Glissez de gauche à droite pour changer de photo.</p>
      <div id="immersion-carousel" class="relative w-full max-w-7xl mx-auto px-4 md:px-12">
          <button type="button" id="carousel-prev" class="absolute left-0 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-white/95 shadow-lg border border-gray-100 flex items-center justify-center text-black hover:bg-[#D4B2A7] hover:text-white hover:border-[#D4B2A7] transition-all" aria-label="Image précédente">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button type="button" id="carousel-next" class="absolute right-0 top-1/2 -translate-y-1/2 z-10 w-12 h-12 rounded-full bg-white/95 shadow-lg border border-gray-100 flex items-center justify-center text-black hover:bg-[#D4B2A7] hover:text-white hover:border-[#D4B2A7] transition-all" aria-label="Image suivante">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </button>
          <div class="overflow-hidden">
              <div id="carousel-track" class="flex gap-6 md:px-4 carousel-infinite carousel-js-driven">
                  {[...carouselImages, ...carouselImages].map((img) => (
                      <div class="carousel-slide relative w-72 md:w-96 aspect-square flex-shrink-0 overflow-hidden group rounded-xl">
                          <img src={img.src} data-fallback="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=800&q=80" alt={img.alt} class="carousel-img w-full h-full object-cover opacity-90 md:grayscale md:opacity-80 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" width="400" height="400" loading="lazy" decoding="async" referrerpolicy="no-referrer" />
                      </div>
                  ))}
              </div>
          </div>
      </div>
  </section>

  <section id="prestations" class="py-32 px-6 bg-[#FCFAF8] page-bg">
      <div class="max-w-6xl mx-auto">
          <div class="text-center mb-16">
              <h2 class="text-4xl md:text-5xl font-serif mb-6 text-black">Nos prestations</h2>
              <p class="text-gray-500 font-light max-w-lg mx-auto">Soins du visage, maquillage, onglerie et épilation. Détail des services et tarifs.</p>
          </div>
          <div class="grid md:grid-cols-2 gap-8 mb-14">
              {prestations.map((item) => (
                  <div class="presta-card group relative p-6 bg-white border border-gray-100 rounded-2xl shadow-[0_10px_40px_rgb(0,0,0,0.04)] hover:shadow-[0_20px_50px_rgb(0,0,0,0.08)] hover:border-[#D4B2A7]/30 transition-all duration-300">
                      <div class="flex gap-5 mb-4">
                          <div class="w-24 h-24 flex-shrink-0 overflow-hidden rounded-xl bg-[#F4EBE8] flex items-center justify-center text-[10px] text-[#D4B2A7] font-bold">Démo</div>
                          <div class="min-w-0 flex-1">
                              <span class="text-[9px] font-bold uppercase tracking-widest text-[#D4B2A7] mb-1 block">{item.category}</span>
                              <h3 class="text-lg font-serif text-black">{item.title}</h3>
                              <p class="text-sm text-gray-500 font-light mt-1">{item.desc}</p>
                          </div>
                      </div>
                      <ul class="space-y-2 text-sm">
                          {item.services.map((s, i) => (
                              <li class="flex justify-between items-baseline gap-4">
                                  <span class="text-gray-700">{s}</span>
                                  <span class="text-[#D4B2A7] font-medium shrink-0">{item.prices[i]}</span>
                              </li>
                          ))}
                      </ul>
                  </div>
              ))}
          </div>
          <div class="text-center">
              <a href="/#agenda" class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-black text-white text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-[#D4B2A7] transition-colors rounded-xl shadow-lg">Prendre rendez-vous</a>
          </div>
      </div>
  </section>

  <section id="agenda" class="py-32 px-6 bg-white border-t border-gray-100 relative">
      <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
          <div class="space-y-8">
              <h2 class="text-4xl md:text-5xl font-serif text-black leading-tight">Prenez du temps <br>pour vous.</h2>
              <p class="text-gray-500 font-light leading-relaxed">Choisissez le jour et l'heure qui vous conviennent. Une confirmation vous sera envoyée. Compatible MyCockpit pour la prise de rendez-vous en ligne.</p>
              <ul class="space-y-4 pt-4">
                  <li class="flex items-center gap-3 text-sm text-gray-700"><svg class="w-5 h-5 text-[#D4B2A7]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Paiement sécurisé ou sur place</li>
                  <li class="flex items-center gap-3 text-sm text-gray-700"><svg class="w-5 h-5 text-[#D4B2A7]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Rappel SMS 24h avant</li>
                  <li class="flex items-center gap-3 text-sm text-gray-700"><svg class="w-5 h-5 text-[#D4B2A7]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Modification gratuite jusqu'à 48h</li>
              </ul>
          </div>
          <div id="agenda-widget" class="bg-white rounded-2xl shadow-[0_20px_50px_rgb(0,0,0,0.08)] border border-gray-100 p-8 md:p-10 relative overflow-hidden">
              <div class="absolute top-0 right-0 w-32 h-32 bg-[#F4EBE8] rounded-bl-full opacity-50"></div>
              <div class="relative z-10">
                  <div class="flex justify-between items-center mb-6 border-b border-gray-100 pb-4">
                      <span class="font-serif text-xl">Sélectionnez une date</span>
                      <div class="flex items-center gap-2">
                          <button type="button" id="agenda-prev-month" class="p-1.5 rounded-lg hover:bg-gray-100 text-gray-500" aria-label="Mois précédent">‹</button>
                          <span id="agenda-month-label" class="text-xs text-gray-600 uppercase tracking-widest font-bold min-w-[7rem] text-center"></span>
                          <button type="button" id="agenda-next-month" class="p-1.5 rounded-lg hover:bg-gray-100 text-gray-500" aria-label="Mois suivant">›</button>
                      </div>
                  </div>
                  <div id="agenda-days" class="grid grid-cols-7 gap-1 mb-6 text-center text-[10px] font-bold uppercase text-gray-400">Lun Mar Mer Jeu Ven Sam Dim</div>
                  <div id="agenda-dates" class="grid grid-cols-7 gap-1 mb-8"></div>
                  <div id="agenda-slots-wrap" class="mb-6 hidden">
                      <span id="agenda-slots-label" class="text-xs text-gray-500 font-bold uppercase tracking-widest mb-3 block"></span>
                      <div id="agenda-slots" class="grid grid-cols-3 gap-2"></div>
                  </div>
                  <p class="text-[10px] text-gray-400 mb-4">Réservation démo. En production : intégration MyCockpit (localsearch.ch) pour confirmer le RDV.</p>
                  <a href="https://ultras-sites.com/#contact" target="_blank" rel="noopener" class="block w-full text-center py-4 bg-black text-white text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-[#D4B2A7] transition-colors rounded-lg">Contact ultras-sites.com</a>
              </div>
          </div>
      </div>
  </section>

  <section id="avis" class="py-32 px-6 bg-[#FCFAF8]">
      <div class="max-w-7xl mx-auto text-center">
          <h2 class="text-3xl font-serif mb-12 text-black">Ce qu'elles en pensent</h2>
          <div class="grid md:grid-cols-3 gap-10">
              {avis.map((avi) => (
                  <div class="bg-white p-10 shadow-[0_10px_40px_rgb(0,0,0,0.03)] border border-gray-50 relative group hover:-translate-y-2 transition-transform duration-500">
                      <div class="text-4xl font-serif text-[#D4B2A7] mb-4">"</div>
                      <p class="text-gray-600 font-light leading-relaxed mb-8 text-sm">{avi.text}</p>
                      <div class="flex items-center justify-center gap-1 mb-3 text-[#D4B2A7]">
                          {[1,2,3,4,5].map(() => <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
                      </div>
                      <p class="text-[10px] font-bold uppercase tracking-widest text-black">{avi.name}</p>
                  </div>
              ))}
          </div>
      </div>
  </section>

  <section id="contact" class="border-t border-gray-200 bg-[#FCFAF8]">
      <div class="max-w-6xl mx-auto px-6 py-20">
          <h2 class="text-4xl md:text-5xl font-serif text-black text-center mb-16">Nous trouver</h2>
          <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 mb-16">
              <div class="bg-white p-10 rounded-2xl shadow-[0_10px_40px_rgb(0,0,0,0.04)] border border-gray-50">
                  <h3 class="text-xl font-serif text-black mb-6">Adresse & contact</h3>
                  <ul class="space-y-5 text-sm font-light text-gray-600">
                      <li class="flex items-start gap-4">
                          <span class="leading-relaxed text-gray-500">Adresse démo · À personnaliser</span>
                      </li>
                      <li class="flex items-center gap-4">
                          <span class="text-gray-500">Démo · Vos coordonnées ici</span>
                      </li>
                  </ul>
                  <a href="https://ultras-sites.com/#contact" target="_blank" rel="noopener" class="inline-block mt-6 px-6 py-3 bg-black text-white text-[10px] font-bold uppercase tracking-[0.2em] hover:bg-[#D4B2A7] transition-colors rounded-sm">ultras-sites.com</a>
              </div>
              <div class="bg-white p-10 rounded-2xl shadow-[0_10px_40px_rgb(0,0,0,0.04)] border border-gray-50">
                  <h3 class="text-xl font-serif text-black mb-6">Demande de contact</h3>
                  <p class="text-xs text-gray-400 mb-6">Formulaire fictif pour la démo. En production, à brancher sur votre envoi d’emails.</p>
                  <form id="formulaire" class="space-y-5">
                      <input type="text" placeholder="Votre nom" class="w-full bg-transparent border-b border-gray-300 py-3 text-black placeholder-gray-400 focus:border-[#D4B2A7] focus:outline-none text-sm" />
