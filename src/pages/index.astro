      <div class="relative h-[50vh] min-h-[400px] w-full bg-gray-200">
          <iframe 
              src="https://maps.google.com/maps?q=Tour%20Eiffel%20Paris&t=&z=15&ie=UTF8&iwloc=&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
