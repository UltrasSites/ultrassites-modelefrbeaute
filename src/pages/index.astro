<style>
    /* Mobile : animation CSS auto (plus rapide), pause au touch pour swipe */
    .carousel-infinite { animation: carousel-scroll 14s linear infinite; }
    .carousel-js-driven.carousel-js-active { animation: none; }
    #immersion-carousel:hover .carousel-infinite:not(.carousel-js-active) { animation-play-state: paused; }
    @keyframes carousel-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
</style>

<script>
    // Hero et Rita : charger l’image locale si elle existe, sinon garder le fallback déjà en src
    document.querySelectorAll<HTMLImageElement>('img[data-original]').forEach((img) => {
        const orig = img.dataset.original;
        if (orig && orig.startsWith('/')) {
            const test = new Image();
            test.onload = () => { img.src = orig; };
            test.src = orig;
        }
    });
    document.querySelectorAll<HTMLImageElement>('img[data-fallback]').forEach((el) => {
        el.addEventListener('error', () => {
            const fallback = el.dataset.fallback;
            if (fallback) el.src = fallback;
        });
    });
    document.querySelectorAll<HTMLImageElement>('.carousel-img, .presta-img').forEach((el) => {
        el.addEventListener('error', () => {
            if (!el.dataset.fallbackUsed) {
                el.src = el.dataset.fallback || 'https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=800&q=80';
                el.dataset.fallbackUsed = '1';
            }
        });
    });

    // Carousel : desktop = défilement proportionnel à la proximité des flèches ; mobile = auto + swipe
    const carousel = document.getElementById('immersion-carousel');
    const track = document.getElementById('carousel-track');
    const slides = document.querySelectorAll('.carousel-slide');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');
    if (!track || !slides.length) {} else {
        const trackEl = track as HTMLElement;
        const isDesktop = () => window.matchMedia('(min-width: 768px)').matches;
        const LOOP_DURATION_MS = 12000;
        const ZONE_PX = 140;
        const PROXIMITY_SPEED = 0.00035;
        let carouselOffsetPx = 0;
        let lastTime = 0;
        let mouseX = -1;
        let rafId: number | null = null;

        function getTrackHalfWidth() {
            return (trackEl.scrollWidth / 2);
        }
        function setTrackTransform(px: number) {
            trackEl.style.transform = `translateX(${px}px)`;
        }

        function tick(t: number) {
            const dt = lastTime ? Math.min(t - lastTime, 80) : 16;
            lastTime = t;
            const half = getTrackHalfWidth();
            let speedPxPerMs = half / LOOP_DURATION_MS;
            if (isDesktop() && carousel && mouseX >= 0) {
                const rect = carousel.getBoundingClientRect();
                const prevRect = prevBtn?.getBoundingClientRect();
                const nextRect = nextBtn?.getBoundingClientRect();
                let add = 0;
                if (prevRect && mouseX >= rect.left && mouseX <= prevRect.right + ZONE_PX) {
                    const dist = Math.max(0, (prevRect.right + ZONE_PX) - mouseX);
                    add = -PROXIMITY_SPEED * (ZONE_PX - dist);
                } else if (nextRect && mouseX >= nextRect.left - ZONE_PX && mouseX <= rect.right) {
                    const dist = Math.max(0, mouseX - (nextRect.left - ZONE_PX));
                    add = PROXIMITY_SPEED * (ZONE_PX - dist);
                }
                speedPxPerMs += add;
            }
            carouselOffsetPx -= speedPxPerMs * dt;
            if (carouselOffsetPx <= -half) carouselOffsetPx += half;
            if (carouselOffsetPx > 0) carouselOffsetPx -= half;
            setTrackTransform(carouselOffsetPx);
            rafId = requestAnimationFrame(tick);
        }

        trackEl.classList.add('carousel-js-active');
        if (isDesktop()) {
            carousel?.addEventListener('mousemove', (e) => { mouseX = e.clientX; });
            carousel?.addEventListener('mouseleave', () => { mouseX = -1; });
        }
        rafId = requestAnimationFrame(tick);

        prevBtn?.addEventListener('click', () => {
            const half = getTrackHalfWidth();
            carouselOffsetPx += half / 5;
            if (carouselOffsetPx > 0) carouselOffsetPx -= half;
            setTrackTransform(carouselOffsetPx);
        });
        nextBtn?.addEventListener('click', () => {
            const half = getTrackHalfWidth();
            carouselOffsetPx -= half / 5;
            if (carouselOffsetPx <= -half) carouselOffsetPx += half;
            setTrackTransform(carouselOffsetPx);
        });

        let touchStartX = 0;
        let touchStartOffset = 0;
        trackEl.addEventListener('touchstart', (e) => {
            touchStartX = (e as TouchEvent).touches[0].clientX;
            touchStartOffset = carouselOffsetPx;
        }, { passive: true });
        trackEl.addEventListener('touchend', (e) => {
            const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
            if (Math.abs(diff) > 50) {
                const half = getTrackHalfWidth();
                const jump = (half / 5) * (diff > 0 ? 1 : -1);
                carouselOffsetPx = touchStartOffset - jump;
                while (carouselOffsetPx <= -half) carouselOffsetPx += half;
                while (carouselOffsetPx > 0) carouselOffsetPx -= half;
                setTrackTransform(carouselOffsetPx);
            }
        }, { passive: true });
    }

    // Agenda réaliste : mois courant, choix de la date, créneaux selon le jour
    const MONTHS = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre'];
    const SLOTS = ['09:00', '09:30', '10:00', '10:30', '11:00', '11:30', '14:00', '14:30', '15:00', '15:30', '16:00', '16:30', '17:00'];
    let agendaYear = new Date().getFullYear();
    let agendaMonth = new Date().getMonth();
    let selectedDate: Date | null = null;

    const monthLabel = document.getElementById('agenda-month-label');
    const datesEl = document.getElementById('agenda-dates');
    const slotsWrap = document.getElementById('agenda-slots-wrap');
    const slotsLabel = document.getElementById('agenda-slots-label');
    const slotsEl = document.getElementById('agenda-slots');
    const prevMonthBtn = document.getElementById('agenda-prev-month');
    const nextMonthBtn = document.getElementById('agenda-next-month');

    function isSameDay(a: Date, b: Date) {
        return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate();
    }
    function isPast(d: Date) {
        const t = new Date();
        t.setHours(0, 0, 0, 0);
        return d < t;
    }
    function isWeekend(d: Date) {
        const day = d.getDay();
        return day === 0 || day === 6;
    }

    function renderAgendaMonth() {
        if (!monthLabel || !datesEl) return;
        monthLabel.textContent = `${MONTHS[agendaMonth]} ${agendaYear}`;
        const first = new Date(agendaYear, agendaMonth, 1);
        const last = new Date(agendaYear, agendaMonth + 1, 0);
        const startPad = (first.getDay() + 6) % 7;
        let html = '';
        for (let i = 0; i < startPad; i++) html += '<div class="aspect-square"></div>';
        for (let d = 1; d <= last.getDate(); d++) {
            const date = new Date(agendaYear, agendaMonth, d);
            const past = isPast(date);
            const weekend = isWeekend(date);
            const sel = selectedDate && isSameDay(date, selectedDate);
            const disabled = past || weekend;
            const cls = disabled ? 'text-gray-300 cursor-not-allowed' : 'cursor-pointer hover:bg-[#F4EBE8] rounded-lg';
            const active = sel ? 'bg-black text-white hover:bg-black' : '';
            html += `<button type="button" class="aspect-square flex items-center justify-center text-sm font-medium ${cls} ${active}" ${disabled ? 'disabled' : ''} data-date="${date.toISOString().slice(0, 10)}">${d}</button>`;
        }
        datesEl.innerHTML = html;
        datesEl.querySelectorAll('button:not([disabled])').forEach((btn) => {
            btn.addEventListener('click', () => {
                const dateStr = (btn as HTMLElement).dataset.date;
                if (!dateStr) return;
                selectedDate = new Date(dateStr + 'T12:00:00');
                renderAgendaMonth();
                renderSlots();
            });
        });
    }

    function renderSlots() {
        if (!slotsWrap || !slotsLabel || !slotsEl) return;
        if (!selectedDate) {
            slotsWrap.classList.add('hidden');
            return;
        }
        const d = selectedDate;
        const dayNames = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];
        slotsLabel.textContent = `Disponibilités — ${dayNames[d.getDay()]} ${d.getDate()} ${MONTHS[d.getMonth()]}`;
        slotsEl.innerHTML = SLOTS.map((slot) => `<button type="button" class="py-2.5 text-center text-sm font-medium border border-gray-200 rounded-lg hover:border-[#D4B2A7] hover:bg-[#F4EBE8] transition-all">${slot}</button>`).join('');
        slotsWrap.classList.remove('hidden');
    }

    prevMonthBtn?.addEventListener('click', () => {
        if (agendaMonth === 0) { agendaMonth = 11; agendaYear--; } else agendaMonth--;
        selectedDate = null;
        renderAgendaMonth();
        slotsWrap?.classList.add('hidden');
    });
    nextMonthBtn?.addEventListener('click', () => {
        if (agendaMonth === 11) { agendaMonth = 0; agendaYear++; } else agendaMonth++;
        selectedDate = null;
        renderAgendaMonth();
        slotsWrap?.classList.add('hidden');
    });
    renderAgendaMonth();
</script>
