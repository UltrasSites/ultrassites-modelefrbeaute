---
import { defaultLang } from '../i18n/utils';
---

<!doctype html>
<html lang={defaultLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Beauty & Wellness</title>
    <script is:inline>
      (function() {
        var supported = ['fr','en','pt','es'];
        var lang = 'fr';
        var params = typeof URLSearchParams !== 'undefined' && window.location.search ? new URLSearchParams(window.location.search) : null;
        var fromUrl = params && params.get('lang');
        if (fromUrl && supported.indexOf(fromUrl) !== -1) {
          lang = fromUrl;
          try { localStorage.setItem('lang', lang); } catch (e) {}
        } else {
          var stored = typeof localStorage !== 'undefined' && localStorage.getItem('lang');
          if (stored && supported.indexOf(stored) !== -1) lang = stored;
          else {
            var nav = typeof navigator !== 'undefined' && (navigator.language || '').toLowerCase();
            if (nav && nav.indexOf('en') === 0) lang = 'en';
            else if (nav && nav.indexOf('pt') === 0) lang = 'pt';
            else if (nav && nav.indexOf('es') === 0) lang = 'es';
          }
        }
        window.location.replace('/' + lang + '/');
      })();
    </script>
  </head>
  <body>
    <p>Redirecting…</p>
  </body>
</html>
