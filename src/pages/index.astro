<script is:inline>
  // Redirection gérée par _redirects
  const langCookie = document.cookie.split('; ').find(row => row.startsWith('lang='))?.split('=')[1];
  if (langCookie === 'en' || langCookie === 'fr') {
    window.location.pathname = `/${langCookie}/`;
  } else {
    window.location.pathname = '/language/';
  }
</script>
