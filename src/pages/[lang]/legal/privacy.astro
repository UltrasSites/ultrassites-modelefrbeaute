---
import BaseLayout from '../../../layouts/BaseLayout.astro';
export async function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
    { params: { lang: 'pt' } },
    { params: { lang: 'es' } },
  ];
}
const { lang } = Astro.params;
const isEn = lang === 'en';
---

<BaseLayout>
  <div class="bg-neutral-50 min-h-screen py-32 px-6 text-slate-800">
    <div class="max-w-3xl mx-auto prose prose-slate">
      <h1>{isEn ? 'Privacy Policy' : 'Politique de Confidentialité'}</h1>
      
      <p>{isEn ? 'Last updated: 2026' : 'Dernière mise à jour : 2026'}</p>

      <h2>{isEn ? '1. Data collection' : '1. Collecte des données'}</h2>
      <p>
        {isEn
          ? "We collect the information you provide via the contact form (Name, Email). These data are used solely to respond to your request."
          : "Nous collectons les informations que vous nous fournissez via le formulaire de contact (Nom, Email). Ces données sont utilisées uniquement pour répondre à votre demande."}
      </p>

      <h2>{isEn ? '2. Cookies' : '2. Cookies'}</h2>
      <p>
        {isEn
          ? "This site does not use intrusive advertising cookies. Only technical cookies required for proper functioning (e.g., language choice) may be set."
          : "Ce site n'utilise pas de cookies publicitaires invasifs. Seuls des cookies techniques nécessaires au bon fonctionnement (ex: choix de la langue) peuvent être déposés."}
      </p>

      <h2>{isEn ? '3. Your rights' : '3. Vos droits'}</h2>
      <p>
        {isEn
          ? "In accordance with GDPR, you have rights to access, rectify, and delete your data. Use the contact form to exercise these rights."
          : "Conformément au RGPD, vous disposez d'un droit d'accès, de rectification et de suppression de vos données. Utilisez le formulaire de contact pour exercer ce droit."}
      </p>
    </div>
  </div>
</BaseLayout>