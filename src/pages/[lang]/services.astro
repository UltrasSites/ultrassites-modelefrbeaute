---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { translations } from '../../i18n/translations';

export async function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params;
const t = translations[lang as 'fr' | 'en'];
---

<BaseLayout>
  <div class="bg-neutral-950 min-h-screen text-white pt-32 pb-24">
    <section class="max-w-7xl mx-auto px-6">
      <div class="text-center max-w-3xl mx-auto mb-20">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">{t.servicesSection}</h1>
        <p class="text-xl text-neutral-400 font-light">{t.servicesSubtitle}</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {t.services.map(service => (
          <ServiceCard title={service.title} desc={service.desc} />
        ))}
      </div>
      
      <div class="mt-32 relative rounded-3xl overflow-hidden bg-neutral-900 border border-white/10 p-12 text-center">
          <div class="absolute inset-0 bg-gradient-to-r from-purple-900/20 to-blue-900/20"></div>
          <div class="relative z-10">
              <h2 class="text-3xl font-bold mb-6">{t.contactTitle}</h2>
              <a href={`/${lang}/contact`} class="inline-block border border-white/30 hover:bg-white hover:text-black text-white px-10 py-4 rounded-full transition-all duration-300 uppercase tracking-widest text-sm font-bold">
                {t.nav.contact}
              </a>
          </div>
      </div>
    </section>
  </div>
</BaseLayout>