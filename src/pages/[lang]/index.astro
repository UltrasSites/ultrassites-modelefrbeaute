---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { translations } from '../../i18n/translations';

export async function getStaticPaths() {
  return [ { params: { lang: 'fr' } }, { params: { lang: 'en' } } ];
}
const { lang } = Astro.params;
const t = translations[lang as 'fr' | 'en'];
---

<BaseLayout>
  <div class="bg-neutral-950 text-white font-sans scroll-smooth">
    
    <section id="home" class="relative h-screen w-full flex items-center justify-center overflow-hidden snap-start">
       <div class="absolute inset-0 z-0">
          <div class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?q=80&w=2072&auto=format&fit=crop')] bg-cover bg-center opacity-40 animate-slow-pan"></div>
          <div class="absolute inset-0 bg-gradient-to-b from-neutral-950/80 via-transparent to-neutral-950"></div>
       </div>

       <div class="relative z-10 text-center px-6">
          <div class="inline-block border border-white/20 px-4 py-1 rounded-full text-[10px] uppercase tracking-[0.4em] mb-8 bg-white/5 backdrop-blur-sm animate-fade-in-up">
            {t.heroSub} Experience
          </div>
          <h1 class="text-6xl md:text-8xl font-serif italic mb-6 leading-none animate-title-reveal">
            {t.heroTitle}
          </h1>
          <p class="text-neutral-400 max-w-lg mx-auto leading-relaxed mb-10 animate-fade-in-up delay-200">
            {t.heroDesc}
          </p>
          <a href="#services" class="group inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest hover:text-emerald-500 transition-colors animate-fade-in-up delay-300">
             Découvrir <span class="group-hover:translate-y-1 transition-transform">↓</span>
          </a>
       </div>
    </section>

    <section id="about" class="min-h-screen flex items-center py-20 relative snap-start">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-20 items-center">
            <div class="relative group">
                <div class="absolute -inset-4 bg-gradient-to-r from-emerald-600 to-blue-600 rounded-2xl opacity-20 group-hover:opacity-40 blur-xl transition duration-1000"></div>
                <div class="relative rounded-xl overflow-hidden aspect-[3/4]">
                    <img src="https://images.unsplash.com/photo-1497215728101-856f4ea42174?q=80&w=2070&auto=format&fit=crop" class="w-full h-full object-cover scale-100 group-hover:scale-110 transition-transform duration-700" alt="Workspace">
                </div>
            </div>
            <div>
                <span class="text-emerald-500 font-bold tracking-widest text-xs uppercase mb-4 block">L'Artisanat Digital</span>
                <h2 class="text-4xl md:text-5xl font-serif italic mb-8">{t.aboutPageTitle}</h2>
                <div class="prose prose-invert prose-lg text-neutral-400 font-light">
                    <p>{t.aboutPageText}</p>
                    <p class="mt-4">
                        Pas de templates. Pas de chargements infinis. Juste du code pur taillé pour la performance. C'est ça, la promesse Signature.
                    </p>
                </div>
                
                <div class="grid grid-cols-3 gap-8 mt-12 border-t border-white/10 pt-8">
                    <div>
                        <span class="block text-3xl font-bold text-white">100<small class="text-sm">%</small></span>
                        <span class="text-xs text-neutral-500 uppercase tracking-widest">Performance</span>
                    </div>
                    <div>
                        <span class="block text-3xl font-bold text-white">0<small class="text-sm">s</small></span>
                        <span class="text-xs text-neutral-500 uppercase tracking-widest">Attente</span>
                    </div>
                    <div>
                        <span class="block text-3xl font-bold text-white">24<small class="text-sm">/7</small></span>
                        <span class="text-xs text-neutral-500 uppercase tracking-widest">Support</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="py-32 bg-neutral-900 border-y border-white/5 relative overflow-hidden">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-purple-900/20 blur-[120px] rounded-full pointer-events-none"></div>

        <div class="max-w-7xl mx-auto px-6 mb-16 text-center">
            <h2 class="text-4xl font-bold mb-4">{t.servicesSection}</h2>
            <p class="text-neutral-400">{t.servicesSubtitle}</p>
        </div>

        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {t.services.map((service, index) => (
                <div class="group p-8 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10 hover:border-emerald-500/30 transition-all duration-500 cursor-default">
                    <div class="text-emerald-500 mb-4 text-2xl opacity-50 font-serif italic">0{index + 1}</div>
                    <h3 class="text-xl font-bold mb-3 group-hover:text-emerald-400 transition-colors">{service.title}</h3>
                    <p class="text-sm text-neutral-400 leading-relaxed">{service.desc}</p>
                </div>
            ))}
        </div>
    </section>

    <section id="blog" class="py-32 px-6 bg-neutral-950 relative border-t border-white/5">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <span class="text-emerald-500 font-bold tracking-widest text-xs uppercase mb-4 block">Stratégie & Contenu</span>
                    <h2 class="text-4xl font-serif italic text-white">Le Journal.</h2>
                </div>
                <a href="#" class="text-sm font-bold text-white uppercase tracking-widest hover:text-emerald-500 transition-colors pb-2 border-b border-white/20 hover:border-emerald-500">
                    Voir tous les articles →
                </a>
            </div>

            <div class="grid md:grid-cols-3 gap-10">
                <article class="group cursor-pointer">
                    <div class="overflow-hidden rounded-xl mb-6 relative aspect-[4/3]">
                        <img src="https://images.unsplash.com/photo-1493612276216-ee3925520721?q=80&w=1964&auto=format&fit=crop" 
                             alt="Blog Post" 
                             class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" />
                        <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors"></div>
                        <div class="absolute top-4 left-4 bg-white/10 backdrop-blur-md px-3 py-1 rounded-full border border-white/20">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-white">SEO</span>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <span class="text-xs text-neutral-500">12 Octobre 2025</span>
                        <h3 class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors leading-tight">
                            Pourquoi le site statique domine Google cette année.
                        </h3>
                        <p class="text-sm text-neutral-400 line-clamp-2">
                            La vitesse n'est plus une option. Découvrez comment l'architecture Astro propulse votre visibilité...
                        </p>
                    </div>
                </article>

                <article class="group cursor-pointer">
                    <div class="overflow-hidden rounded-xl mb-6 relative aspect-[4/3]">
                        <img src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?q=80&w=2070&auto=format&fit=crop" 
                             alt="Blog Post" 
                             class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" />
                         <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors"></div>
                         <div class="absolute top-4 left-4 bg-white/10 backdrop-blur-md px-3 py-1 rounded-full border border-white/20">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-white">Design</span>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <span class="text-xs text-neutral-500">28 Septembre 2025</span>
                        <h3 class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors leading-tight">
                            L'impact du "Dark Mode" sur la conversion client.
                        </h3>
                        <p class="text-sm text-neutral-400 line-clamp-2">
                            Une interface sombre n'est pas qu'esthétique, elle réduit la fatigue oculaire et augmente le temps passé...
                        </p>
                    </div>
                </article>

                <article class="group cursor-pointer">
                    <div class="overflow-hidden rounded-xl mb-6 relative aspect-[4/3]">
                        <img src="https://images.unsplash.com/photo-1504384308090-c54be3855463?q=80&w=1964&auto=format&fit=crop" 
                             alt="Blog Post" 
                             class="w-full h-full object-cover transform group-hover:scale-110 transition-transform duration-700" />
                         <div class="absolute inset-0 bg-black/20 group-hover:bg-black/0 transition-colors"></div>
                         <div class="absolute top-4 left-4 bg-white/10 backdrop-blur-md px-3 py-1 rounded-full border border-white/20">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-white">Tech</span>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <span class="text-xs text-neutral-500">15 Septembre 2025</span>
                        <h3 class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors leading-tight">
                            Sécurité web : pourquoi abandonner WordPress ?
                        </h3>
                        <p class="text-sm text-neutral-400 line-clamp-2">
                            Les failles de sécurité des CMS coûtent cher. Le code pur offre une forteresse imprenable pour vos données.
                        </p>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section id="contact" class="min-h-screen flex items-center justify-center py-20 px-6 relative">
        <div class="max-w-4xl w-full bg-neutral-900/50 backdrop-blur-md border border-white/10 p-8 md:p-16 rounded-3xl shadow-2xl">
            <div class="text-center mb-12">
                <h2 class="text-4xl font-serif italic mb-4">{t.contactTitle}</h2>
                <p class="text-neutral-400">{t.contactText}</p>
            </div>

            <form class="space-y-6">
                <div class="grid md:grid-cols-2 gap-6">
                    <input type="text" placeholder="Nom" class="w-full bg-black/30 border border-white/10 rounded-lg px-6 py-4 focus:border-emerald-500 focus:outline-none transition-colors" />
                    <input type="email" placeholder="Email" class="w-full bg-black/30 border border-white/10 rounded-lg px-6 py-4 focus:border-emerald-500 focus:outline-none transition-colors" />
                </div>
                <textarea rows="4" placeholder="Votre projet en quelques mots..." class="w-full bg-black/30 border border-white/10 rounded-lg px-6 py-4 focus:border-emerald-500 focus:outline-none transition-colors"></textarea>
                
                <button class="w-full bg-emerald-600 hover:bg-emerald-500 text-white font-bold uppercase tracking-widest py-5 rounded-lg transition-all duration-300 shadow-[0_0_20px_rgba(16,185,129,0.3)] hover:shadow-[0_0_40px_rgba(16,185,129,0.5)] transform hover:-translate-y-1">
                    Lancer la collaboration
                </button>
            </form>
        </div>
    </section>

  </div>
</BaseLayout>

<style>
    /* CSS Pur pour les animations simples */
    html {
        scroll-behavior: smooth;
    }
    
    .animate-slow-pan {
        animation: panImage 30s infinite alternate linear;
    }
    
    @keyframes panImage {
        0% { transform: scale(1.1) translate(0, 0); }
        100% { transform: scale(1.2) translate(-20px, -10px); }
    }

    .animate-fade-in-up {
        animation: fadeInUp 1s ease-out forwards;
        opacity: 0;
        transform: translateY(20px);
    }
    
    .animate-title-reveal {
        animation: revealTitle 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards;
        opacity: 0;
        transform: translateY(50px) scale(0.95);
    }

    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }

    @keyframes fadeInUp {
        to { opacity: 1; transform: translateY(0); }
    }
    @keyframes revealTitle {
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
</style>

<script>
    // Petit script pour mettre à jour le lien actif dans le header pendant le scroll
    const sections = document.querySelectorAll('section');
    const navLinks = document.querySelectorAll('.nav-link');

    window.addEventListener('scroll', () => {
        let current = '';
        sections.forEach(section => {
            const sectionTop = section.offsetTop;
            const sectionHeight = section.clientHeight;
            if (scrollY >= (sectionTop - sectionHeight / 3)) {
                current = section.getAttribute('id') || '';
            }
        });

        navLinks.forEach(link => {
            link.classList.remove('text-emerald-400');
            link.classList.add('text-white'); // Reset
            if (link.getAttribute('href')?.includes('#' + current)) {
                link.classList.remove('text-white');
                link.classList.add('text-emerald-400');
            }
        });
    });
</script>