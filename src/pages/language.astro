---
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PRO+ Language</title>
  <link rel="icon" type="image/png" href="/pro+.png" />
  <style>
    body {
      background-color: #050505; color: #fff;
      font-family: system-ui, -apple-system, sans-serif;
      height: 100vh; display: flex; align-items: center; justify-content: center;
      margin: 0;
    }
    .card {
      text-align: center; border: 1px solid rgba(255,255,255,0.1);
      padding: 3rem; border-radius: 1rem;
      background: linear-gradient(to bottom, #111, #050505);
      box-shadow: 0 0 40px rgba(16, 185, 129, 0.1);
    }
    h1 { font-size: 1.5rem; letter-spacing: 0.1em; margin-bottom: 2rem; text-transform: uppercase; color: #aaa; }
    button {
      background: transparent; border: 1px solid #333; color: white;
      padding: 1rem 2rem; margin: 0 0.5rem; cursor: pointer;
      font-weight: bold; transition: 0.3s; border-radius: 0.5rem;
    }
    button:hover {
      border-color: #10b981; color: #10b981; box-shadow: 0 0 15px rgba(16, 185, 129, 0.3);
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>Select Language</h1>
    <div>
      <button id="fr">FRANÇAIS</button>
      <button id="en">ENGLISH</button>
      <button id="pt">PORTUGUÊS</button>
      <button id="es">ESPAÑOL</button>
    </div>
  </div>
  <script is:inline>
    function go(l) {
      if (l !== 'fr' && l !== 'en' && l !== 'pt' && l !== 'es') return;
      document.cookie = `lang=${l}; Path=/; Max-Age=31536000; SameSite=Lax`;
      window.location.href = `/${l}/`;
    }
    document.getElementById('fr').addEventListener('click', () => go('fr'));
    document.getElementById('en').addEventListener('click', () => go('en'));
    document.getElementById('pt').addEventListener('click', () => go('pt'));
    document.getElementById('es').addEventListener('click', () => go('es'));

    const c = document.cookie.split('; ').find(r => r.startsWith('lang='));
    if(c) {
       const l = c.split('=')[1];
       if(l==='fr'||l==='en'||l==='pt'||l==='es') window.location.replace(`/${l}/`);
    }
  </script>
</body>
</html>