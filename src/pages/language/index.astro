---
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/pro+.png" />
  <title>Choisissez votre langue / Choose your language</title>
  
  <style is:inline>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    html, body {
      width: 100%;
      height: 100%;
      font-family: system-ui, -apple-system, sans-serif;
      background: #0a0a0a;
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    
    .container {
      text-align: center;
      max-width: 500px;
      padding: 2rem;
    }
    
    h1 {
      font-size: 1.75rem;
      font-weight: 700;
      margin-bottom: 3rem;
      line-height: 1.4;
    }
    
    .buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
    }
    
    button {
      flex: 1;
      padding: 1.25rem 2rem;
      font-size: 1rem;
      font-weight: 600;
      border: none;
      border-radius: 0.75rem;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    
    .btn-fr {
      background: #059669;
      color: white;
    }
    
    .btn-fr:hover {
      background: #047857;
      transform: translateY(-2px);
    }
    
    .btn-en {
      background: #1f2937;
      color: white;
    }
    
    .btn-en:hover {
      background: #111827;
      transform: translateY(-2px);
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Choisissez votre langue / Choose your language</h1>
    <div class="buttons">
      <button id="btn-fr" class="btn-fr">Français</button>
      <button id="btn-en" class="btn-en">English</button>
    </div>
  </div>

  <script is:inline>
    (function() {
      function setLanguage(lang) {
        if (lang !== 'fr' && lang !== 'en') return;
        
        // Définir le cookie
        document.cookie = `lang=${lang}; path=/; max-age=${60 * 60 * 24 * 365}; SameSite=Lax; Secure`;
        
        // Rediriger vers /{lang}/
        window.location.href = `/${lang}/`;
      }
      
      document.getElementById('btn-fr')?.addEventListener('click', () => setLanguage('fr'));
      document.getElementById('btn-en')?.addEventListener('click', () => setLanguage('en'));
    })();
  </script>
</body>
</html>
